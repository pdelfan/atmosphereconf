---
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/ui/card.astro";
import { getCollection } from "astro:content";

const { id } = Astro.params;

const schedule = await getCollection("events");
const entry = schedule.find((e) => e.id === id);

const showTypes = new Set([
  "presentation",
  "lightning-talk",
  "panel",
  "workshop",
]);

if (!entry || !showTypes.has(entry.data.type)) {
  return Astro.redirect("/talks");
}

const { title, type, speakers, description, category, room, start, end } =
  entry.data;

const typeNames: Record<string, string> = {
  presentation: "Presentation",
  "lightning-talk": "Lightning Talk",
  panel: "Discussion / Panel",
  workshop: "Workshop",
};

const badgeColors: Record<string, string> = {
  presentation: "bg-blue-100 text-blue-700",
  "lightning-talk": "bg-amber-100 text-amber-700",
  panel: "bg-purple-100 text-purple-700",
  workshop: "bg-emerald-100 text-emerald-700",
};

const plainTitle = title.replace(/<[^>]*>/g, "");

function formatTime(iso: string) {
  const m = iso.match(/T(\d{2}):(\d{2})/);
  if (!m) return iso;
  let h = parseInt(m[1]);
  const min = m[2];
  const p = h >= 12 ? "PM" : "AM";
  h = h === 0 ? 12 : h > 12 ? h - 12 : h;
  return min === "00" ? `${h} ${p}` : `${h}:${min} ${p}`;
}

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString("en-US", {
    weekday: "long",
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}

const timeDisplay =
  start && end
    ? `${formatTime(start)} – ${formatTime(end)}`
    : start
      ? formatTime(start)
      : null;

const dateDisplay = start ? formatDate(start) : null;
---

<Layout title={`${plainTitle} — ATmosphereConf 2026`}>
  <div class="mt-20 space-y-10">
    <Card>
      <a
        href="/talks"
        class="text-muted-foreground hover:text-foreground text-sm transition-colors"
      >
        &larr; All Talks
      </a>

      <div class="mt-4">
        <span
          class:list={[
            "inline-block rounded-full px-2.5 py-0.5 text-xs font-medium",
            badgeColors[type] || "bg-gray-100 text-gray-600",
          ]}
        >
          {typeNames[type]}
        </span>

        {
          category && (
            <span class="text-muted-foreground ml-2 text-xs">{category}</span>
          )
        }
      </div>

      <h1
        class="mt-3 text-xl leading-tight font-bold text-gray-900"
        set:html={title}
      />

      {
        speakers?.length && (
          <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1">
            {speakers.map((s) => (
              <span class="text-sm text-gray-600">
                {s.name}
                {s.id && (
                  <>
                    {" · "}
                    <a
                      href={`/profile/${s.id}`}
                      class="text-blue-600 hover:underline"
                    >
                      @{s.id}
                    </a>
                  </>
                )}
              </span>
            ))}
          </div>
        )
      }

      {
        (dateDisplay || timeDisplay || room) && (
          <div class="mt-5 flex flex-col gap-2 text-sm text-gray-600">
            {dateDisplay && (
              <div class="flex items-center gap-2">
                <svg
                  class="h-4 w-4 flex-none text-gray-400"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"
                  />
                </svg>
                <span>{dateDisplay}</span>
              </div>
            )}
            {timeDisplay && (
              <div class="flex items-center gap-2">
                <svg
                  class="h-4 w-4 flex-none text-gray-400"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
                  />
                </svg>
                <span>{timeDisplay}</span>
              </div>
            )}
            {room && (
              <div class="flex items-center gap-2">
                <svg
                  class="h-4 w-4 flex-none text-gray-400"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                  />
                </svg>
                <span>{room}</span>
              </div>
            )}
          </div>
        )
      }

      {
        description && (
          <p class="mt-5 text-sm leading-relaxed whitespace-pre-line text-gray-700">
            {description}
          </p>
        )
      }
    </Card>
  </div>
</Layout>
