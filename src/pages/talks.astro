---
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/ui/card.astro";
import StarringCard from "@/components/home/StarringCard.astro";
import { getCollection } from "astro:content";

const schedule = await getCollection("events");

const typeNames: Record<string, string> = {
  presentation: "Presentation",
  "lightning-talk": "Lightning Talk",
  panel: "Discussion / Panel",
  workshop: "Workshop",
};

const allTalks = schedule
  .filter((t) => t.data.type in typeNames)
  .map((t) => ({
    id: t.id,
    ...t.data,
    typeName: typeNames[t.data.type],
  }));

const types = [
  "Presentation",
  "Lightning Talk",
  "Discussion / Panel",
  "Workshop",
] as const;
const typeLabels: Record<string, string> = {
  Presentation: "Presentations",
  "Lightning Talk": "Lightning Talks",
  "Discussion / Panel": "Discussions & Panels",
  Workshop: "Workshops",
};
const grouped = Object.groupBy(allTalks, (t) => t.typeName);
---

<Layout title="All Talks — ATmosphereConf 2026">
  <div class="mt-20 space-y-10">
    {
      types.map((type) => {
        const talks = grouped[type];
        if (!talks?.length) return null;
        return (
          <Card title={typeLabels[type]}>
            <div class="mt-2 flex flex-col gap-3">
              {talks.map((talk) => (
                <StarringCard
                  talkId={talk.id}
                  title={talk.title}
                  speakers={talk.speakers}
                  typeName={talk.typeName}
                  description={talk.description}
                />
              ))}
            </div>
          </Card>
        );
      })
    }
  </div>
</Layout>
