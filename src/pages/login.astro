---
import Layout from "../layouts/Layout.astro";
import Card from "@/components/ui/card.astro";
import { LoginForm } from "@/components/profile/login/LoginForm";

// Redirect if already logged in
if (Astro.locals.loggedInUser) {
  return Astro.redirect("/profile");
}

// Show error from failed callback or authproto session error
const error =
  Astro.locals.authproto?.errorDescription ||
  Astro.url.searchParams.get("error");
---

<Layout title="Sign In - Atmosphere Conference">
  <div class="flex flex-1 items-center justify-center">
    <Card class="w-full max-w-sm p-8">
      <h1 class="mb-2 text-center text-2xl font-bold text-gray-900">Sign In</h1>
      <p class="mb-6 text-center text-gray-600">
        Sign in with your AT Protocol account
      </p>

      <LoginForm client:load error={error} />

      <p class="mt-6 text-center text-sm text-gray-600">
        Don't have an AT Protocol account?{" "}
        <a
          href="https://bsky.app"
          target="_blank"
          rel="noopener"
          class="font-medium text-[#667eea] hover:underline"
        >
          Sign up
        </a>
      </p>
    </Card>
  </div>
</Layout>
