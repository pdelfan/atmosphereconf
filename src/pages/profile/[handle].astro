---
import Layout from "../../layouts/Layout.astro";
import ProfilePage from "@/components/profile/ProfilePage.astro";
import { loadProfile } from "@/lib/profile";
import { getTalksByHandle } from "@/lib/talks";
import { fetchLatestPost } from "@/lib/bsky";

const { handle } = Astro.params;
const profile = await loadProfile(handle!);
const viewerDid = Astro.locals.loggedInUser?.did;

if (!profile) return Astro.redirect("/404");

const isSpeaker = (await getTalksByHandle(profile.handle)).length > 0;
if (!viewerDid && !isSpeaker) return Astro.redirect("/login");

const latestPost = await fetchLatestPost(profile.handle);

const isOwnProfile = viewerDid === profile.did;
const editData = isOwnProfile
  ? {
      initialDisplayName: profile.displayName,
      initialDescription: profile.description || "",
      initialBio: profile.bio || "",
      initialInterests: profile.interests?.join(", ") || "",
      initialPronouns: profile.pronouns || "",
      initialWebsite: profile.website || "",
      initialLocation: profile.homeTown?.value
        ? { name: profile.homeTown.name ?? "", h3Index: profile.homeTown.value }
        : null,
      currentAvatarUrl: profile.avatarUrl || null,
      existingAvatarBlob: profile.confAvatarBlob,
    }
  : undefined;
---

<Layout title={`${profile.displayName} - Atmosphere Conference`}>
  <ProfilePage {profile} {editData} {viewerDid} {latestPost} />
</Layout>
