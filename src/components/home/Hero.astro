---
import GoodStuff from "@/assets/goodstuff-goose.png";
import { Image } from "astro:assets";
import TicketStubLink from "./TicketStubLink.astro";
---

<div
  data-hero
  class="mr-[calc(50%-50vw)] ml-[calc(50%-50vw)] flex w-screen flex-col items-center justify-center gap-2 px-6 py-8 md:gap-10 md:px-10 md:py-8 lg:flex-row"
  style="background: var(--hero-bg, var(--card)); color: var(--hero-fg, var(--card-foreground)); border-style: var(--hero-border-style, none); border-width: var(--hero-border-width, 0); border-color: var(--hero-border-color, transparent);"
>
  <Image
    data-hero-goose
    class="h-auto w-72 max-w-sm lg:w-full"
    src={GoodStuff}
    width={528 * 1.5}
    height={660 * 1.5}
    alt="Conference mascot Goodstuff"
  />
  <div class="flex flex-col content-center items-center gap-2 md:gap-10">
    <div>
      <h1
        class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-7xl"
        style="color: var(--hero-title, var(--foreground));"
      >
        <span style="color: var(--hero-title-accent, var(--primary));">AT</span>mosphereConf
      </h1>
      <p class="mt-4 text-lg md:text-2xl" style="color: var(--hero-subtitle, var(--muted-foreground));">

        the global AT Protocol community conference
      </p>
    </div>
    <div
      class="col-auto grid w-fit grid-cols-[auto_auto] items-center gap-x-2 text-4xl"
      style="font-family: var(--font-ui);"
    >
      <div
        class="text-muted-foreground self-end justify-self-end text-base tracking-wider uppercase"
      >
        Preshow
      </div><time class="text-4xl">March 26-27 &</time>
      <div
        class="text-muted-foreground self-start justify-self-end text-base tracking-wider uppercase"
      >
        Conference
      </div><time class="text-4xl">March 28-29, 2026</time>
    </div>
    <div class="flex flex-col gap-1 text-center text-pretty">
      <div class="text-foreground text-xl">
        see you @
        <a
          class="text-primary underline"
          href="https://maps.app.goo.gl/nHrbn1fzRpjv1Udk9">UBC campus</a
        >, Vancouver, BC, Canada ...or <a
          class="text-primary underline"
          href="/remote">remote</a
        >!
      </div>
    </div>
    <TicketStubLink />
    <a href="#tickets" class="ngerakines-ticket-btn" style="display: none;">
      🪿 GET YOUR TICKETS 🪿
    </a>
  </div>
</div>
