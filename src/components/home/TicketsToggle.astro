---
import TitoWidget from "@/components/shared/TitoWidget.astro";
---

<p class="text-foreground mx-auto max-w-[65ch]">
  <span class="group-[.remote]:hidden">Can't make it there?</span>
  <span class="group-[.live]:hidden">Want to mingle?</span>

  <a
    href="/remote#tickets"
    class="text-primary cursor-pointer underline group-[.remote]:hidden"
    >Go remote →</a
  >
  <a
    href="/#tickets"
    class="text-primary cursor-pointer underline group-[.live]:hidden"
    >Join us on campus ←</a
  >
</p>

<div class="tito-widgets">
  <TitoWidget type="live" class:list="group-[.remote]:hidden" />
  <TitoWidget type="remote" class:list="group-[.live]:hidden" />
</div>
<a href="https://ti.to/atmosphereconf/2026" class="ngerakines-buy-btn" style="display: none;" target="_blank" rel="noopener">
  BUY TICKETS NOW!!!
</a>
